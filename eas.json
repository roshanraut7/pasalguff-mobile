
{
  "cli": {
    "version": ">= 18.11.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
     "env": {
  "EXPO_PUBLIC_API_URL": "http://192.168.1.77:3000",
  "EXPO_PUBLIC_AUTH_URL": "http://192.168.1.77:3000",
  "EXPO_PUBLIC_APP_WEB_URL": "http://192.168.1.77:3000",
  "EXPO_PUBLIC_APP_SCHEME": "kamkuro"
}
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
     "env": {
  "EXPO_PUBLIC_API_URL": "https://kamkuro.com",
  "EXPO_PUBLIC_AUTH_URL": "https://kamkuro.com",
  "EXPO_PUBLIC_APP_WEB_URL": "https://kamkuro.com",
  "EXPO_PUBLIC_APP_SCHEME": "kamkuro"
}
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "channel": "production",
      
      "android": {
        "buildType": "app-bundle"
      },
     "env": {
  "EXPO_PUBLIC_API_URL": "https://kamkuro.com",
  "EXPO_PUBLIC_AUTH_URL": "https://kamkuro.com",
  "EXPO_PUBLIC_APP_WEB_URL": "https://kamkuro.com",
  "EXPO_PUBLIC_APP_SCHEME": "kamkuro"
}
    }
  },
  "submit": {
    "production": {}
  }
}
