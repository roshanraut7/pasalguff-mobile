{
  "expo": {
    "name": "kamkuro",
    "slug": "pasalguff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/kamkuro.png",
    "scheme": "kamkuro",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
     "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kamkuro.app",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["whatsapp", "fb-messenger", "tg"]
      }
    },
    "android": {
      "package": "com.kamkuro.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/kamkuro.png",
        "monochromeImage": "./assets/images/kamkuro.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/kamkuro.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow KamKuro to access your photos so you can update profile, cover images, and send media in chat.",
          "cameraPermission": "Allow KamKuro to use your camera so you can take profile photos, cover photos, and chat images."
        }
      ],
      "expo-video",
      "expo-web-browser",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow KamKuro to access your microphone so you can send voice messages.",
          "recordAudioAndroid": true,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f046bc29-0ea1-4d7d-a66e-e6e5cc7a3c4a"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f046bc29-0ea1-4d7d-a66e-e6e5cc7a3c4a"
    },
    "owner": "roshan_1"
  }
}
